# =============================================================================
# B&B BOOKING SITE — VARIABILI D'AMBIENTE
# Copia questo file in .env.local e compila tutti i campi obbligatori (*)
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE POSTGRESQL (*)
# Crea un database gratuito su https://neon.tech
# Copia la "Connection string" dal pannello Neon (formato postgres://...)
# Lo schema viene creato automaticamente al primo avvio.
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://user:password@host/dbname

# -----------------------------------------------------------------------------
# STRIPE — PAGAMENTI (*)
# Crea un account su https://stripe.com
# Chiavi di test: https://dashboard.stripe.com/test/apikeys
# Chiavi di produzione: https://dashboard.stripe.com/apikeys
# Webhook: https://dashboard.stripe.com/webhooks → aggiungi endpoint
#   URL: https://<tuo-dominio>/api/stripe/webhook
#   Eventi da selezionare: checkout.session.completed
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Alias espliciti opzionali (hanno precedenza sui due sopra se valorizzati):
STRIPE_SECRET_KEY_TEST=
STRIPE_WEBHOOK_SECRET_TEST=
# Produzione — imposta SOLO quando vai live, poi attiva la modalità da /admin/stripe.
# La modalità attiva è controllata dal flag "mode" in src/data/stripe.json (toggle
# dalla pagina admin, protetta da Authenticator/TOTP). Le chiavi restano solo qui in env.
STRIPE_SECRET_KEY_LIVE=
STRIPE_WEBHOOK_SECRET_LIVE=

# Sicurezza pagina /admin/stripe (TOTP)
# (Opzionale) Cifra il secret TOTP a riposo nel DB. Genera: openssl rand -base64 33
TOTP_ENC_KEY=
# (Opzionale) Fattori di recupero per RESETtare l'authenticator (telefono perso).
# Se nessuno dei due è impostato, qualsiasi admin loggato può resettare.
STRIPE_ADMIN_RESET_PASSPHRASE=
STRIPE_ADMIN_EMAILS=

# -----------------------------------------------------------------------------
# RESEND — EMAIL TRANSAZIONALI (*)
# Crea un account su https://resend.com
# Aggiungi e verifica il tuo dominio email
# Crea una API key con permessi di invio
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...

# -----------------------------------------------------------------------------
# GITHUB — AUTENTICAZIONE ADMIN E SALVATAGGIO DATI (*)
#
# 1. OAuth App per il login admin:
#    https://github.com/settings/developers → OAuth Apps → New OAuth App
#    Homepage URL: https://<tuo-dominio>
#    Authorization callback URL: https://<tuo-dominio>/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# 2. Secret per le sessioni (genera con: openssl rand -base64 33)
AUTH_SECRET=

# 3. GitHub username/i autorizzati ad accedere all'admin (separati da virgola)
#    Usato dal login "Accedi con GitHub".
ADMIN_GITHUB_LOGINS=tuo-username-github

# 3b. Email autorizzate al login "magic-link" (separate da virgola).
#     Il pannello admin offre due metodi di login: GitHub e link via email.
#     Solo gli indirizzi qui elencati possono richiedere/usare il magic-link.
#     Lascia vuoto per disabilitare il login via email (resta solo GitHub).
ADMIN_EMAILS=

# 3c. (Opzionale) Mittente del magic-link. Default: lo stesso indirizzo delle
#     email transazionali (bookingEmail in content.json), sul dominio verificato
#     in Resend. Impostalo solo se vuoi un mittente diverso (es. no-reply@...).
AUTH_EMAIL_FROM=

# 4. Bot token per scrivere content.json e policies.json via API GitHub
#    https://github.com/settings/tokens → Fine-grained token
#    Repository: solo questo repo
#    Permessi: Contents → Read and write
GITHUB_BOT_TOKEN=github_pat_...

# 5. Coordinate del repository
GITHUB_REPO_OWNER=tuo-username-github
GITHUB_REPO_NAME=nome-repo
GITHUB_DATA_BRANCH=main

# -----------------------------------------------------------------------------
# URL DEL SITO (*)
# Usato per generare i link nelle email (conferma, pagamento, ricevuta)
# In sviluppo: http://localhost:3000
# In produzione: https://tuo-dominio.vercel.app oppure https://www.tuodominio.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://tuo-dominio.vercel.app

# -----------------------------------------------------------------------------
# PORTALE (opzionale)
# Se questa struttura fa parte di un portale multi-struttura (repo dimora-portal),
# imposta l'URL del portale: (1) la nav admin mostra lo switcher «Le tue strutture ▾»
# per saltare ai pannelli delle altre strutture; (2) il footer pubblico mostra un link
# "scopri tutte le nostre dimore" verso la home del portale.
# NEXT_PUBLIC_PORTAL_NAME (opzionale) = nome del brand mostrato in quel link.
# Lascia vuoto per una struttura singola.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PORTAL_URL=
NEXT_PUBLIC_PORTAL_NAME=

# -----------------------------------------------------------------------------
# DATI PUBBLICI HOST
# Usati nella pagina di gestione prenotazione lato ospite.
# Devono corrispondere ai valori in content.json.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_HOST_EMAIL=info@esempio.com
NEXT_PUBLIC_HOST_PHONE=+39 000 0000000
NEXT_PUBLIC_CHECKIN_ADDRESS=Via Esempio 1, Città

# -----------------------------------------------------------------------------
# CRON JOB — PROMEMORIA SALDO (opzionale)
# Vercel esegue automaticamente /api/cron/balance-reminder ogni giorno.
# Genera un secret casuale (es. openssl rand -base64 24) e inseriscilo
# sia qui che nel pannello Vercel come variabile d'ambiente.
# -----------------------------------------------------------------------------
CRON_SECRET=

# -----------------------------------------------------------------------------
# ANTHROPIC — TRADUZIONE AUTOMATICA CONTENUTI (opzionale)
# Se configurata, il pannello admin può tradurre automaticamente i testi
# nelle 9 lingue supportate usando Claude AI.
# https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
