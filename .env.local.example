# Auth.js (NextAuth) - GitHub OAuth App credentials
# Create one at https://github.com/settings/developers -> OAuth Apps -> New OAuth App
# Authorization callback URL: <your-site-url>/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Random secret used to sign session tokens. Generate with: openssl rand -base64 33
AUTH_SECRET=

# Comma-separated GitHub usernames (logins) allowed to access /admin
ADMIN_GITHUB_LOGINS=

# Repository where the admin panel commits availability/pricing changes
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=your-repo-name
GITHUB_DATA_BRANCH=main
